{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  //日志清理
  "LogCleanup": {
    "IsEnabled": true,
    "RetentionDays": 2,
    "CheckIntervalHours": 1,
    "LogDirectory": "logs"
  },
  //S7 PLC 连接配置
  "S7Connection": {
    //连接名称（用于日志/诊断区分，可为空）
    "Name": "MainS7",
    //PLC IP 地址或主机名（不要包含端口）
    "Host": "127.0.0.1",
    //PLC 端口（ISO-on-TCP 通常为 102）
    "Port": 102,
    //机架号（S7-1200/1500 常用 0）
    "Rack": 0,
    //槽号（S7-1200/1500 常用 1）
    "Slot": 1,
    //CPU 型号（与 S7CpuType 枚举值一致）
    "CpuType": "S71200",

    //连接超时（毫秒）
    "ConnectTimeoutMs": 1500,
    //读超时（毫秒）
    "ReadTimeoutMs": 1500,
    //写超时（毫秒）
    "WriteTimeoutMs": 1500,

    //轮询周期（毫秒），用于监测连接状态
    "MonitorPollIntervalMs": 20,

    //是否启用自动重连
    "IsAutoReconnectEnabled": true,
    //初始重连延迟（毫秒）
    "ReconnectInitialDelayMs": 500,
    //最大重连延迟（毫秒）
    "ReconnectMaxDelayMs": 10000,
    //最大重连次数（0 或负数表示不限）
    "ReconnectMaxAttempts": 0
  },
  //监控点位配置
  "ElevatorHandshakeDb": {
    "DbNumber": 1,
    "Fields": [
      {
        "Role": "ItemCode",
        "ValueType": "S7String",
        "ByteOffset": 0,
        "MaxStringLength": 254,
        "Remark": "物料编号"
      },
      {
        "Role": "BatchNo",
        "ValueType": "S7String",
        "ByteOffset": 256,
        "MaxStringLength": 254,
        "Remark": "批次"
      },

      {
        "Role": "BoxQuantity",
        "ValueType": "Int16",
        "ByteOffset": 40,
        "Remark": "箱子数量"
      },
      {
        "Role": "CallElevatorLayer",
        "ValueType": "Int16",
        "ByteOffset": 514,
        "Remark": "呼叫电梯层数"
      },
      {
        "Role": "CallElevatorUseLayer",
        "ValueType": "Int16",
        "ByteOffset": 516,
        "Remark": "呼叫电梯使用层数"
      },

      {
        "Role": "CallElevatorSignal",
        "ValueType": "Bool",
        "ByteOffset": 0,
        "BitOffset": 0,
        "Remark": "呼叫电梯信号"
      },
      {
        "Role": "InfeedDoneSignal",
        "ValueType": "Bool",
        "ByteOffset": 10,
        "BitOffset": 1,
        "Remark": "进料完成"
      },
      {
        "Role": "ElevatorArrivedSignal",
        "ValueType": "Bool",
        "ByteOffset": 20,
        "BitOffset": 2,
        "Remark": "电梯到位"
      },

      {
        "Role": "UniqueGuid",
        "ValueType": "S7String",
        "ByteOffset": 520,
        "MaxStringLength": 254,
        "Remark": "唯一Id"
      },
      {
        "Role": "IsSuccess",
        "ValueType": "S7String",
        "ByteOffset": 776,
        "MaxStringLength": 254,
        "Remark": "返回状态: True/False"
      }
    ]
  }
}
