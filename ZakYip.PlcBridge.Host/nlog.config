<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="logs/nlog-internal.txt">

	<targets>
		<!-- Host 模块日志 -->
		<target xsi:type="File" name="hostFile" createDirs="true"
				fileName="logs/host-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/host-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- PLC 模块日志 -->
		<target xsi:type="File" name="plcFile" createDirs="true"
				fileName="logs/plc-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/plc-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- ApiClient 模块日志 -->
		<target xsi:type="File" name="apiClientFile" createDirs="true"
				fileName="logs/apiclient-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/apiclient-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- UsageLimit 模块日志 -->
		<target xsi:type="File" name="usageLimitFile" createDirs="true"
				fileName="logs/usage-limit-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/usage-limit-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- 全局错误日志（兜底落盘） -->
		<target xsi:type="File" name="errorFile" createDirs="true"
				fileName="logs/errors-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/errors-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="30" />

		<target xsi:type="Console" name="console"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<target xsi:type="Null" name="blackhole" />
	</targets>

	<rules>
		<!-- PLC：ZakYip.PlcBridge.Drivers.*（S7PlcManager 在该命名空间） -->
		<logger name="ZakYip.PlcBridge.Drivers.*" minlevel="Trace" writeTo="plcFile,console" final="true" />
		<logger name="ZakYip.PlcBridge.Drivers.*" minlevel="Error" writeTo="errorFile,plcFile,console" final="true" />

		<!-- ApiClient：ZakYip.PlcBridge.Ingress.*（HttpElevatorApiClient 在该命名空间） -->
		<logger name="ZakYip.PlcBridge.Ingress.*" minlevel="Trace" writeTo="apiClientFile,console" final="true" />
		<logger name="ZakYip.PlcBridge.Ingress.*" minlevel="Error" writeTo="errorFile,apiClientFile,console" final="true" />

		<!-- UsageLimit：logger 名称包含 UsageLimit 的统一归档（当前代码未出现该关键词，先做规则兜底） -->
		<logger name="*UsageLimit*" minlevel="Trace" writeTo="usageLimitFile,console" final="true" />
		<logger name="*UsageLimit*" minlevel="Error" writeTo="errorFile,usageLimitFile,console" final="true" />

		<!-- Host：ZakYip.PlcBridge.Host.*（HostedService 在该命名空间） -->
		<logger name="ZakYip.PlcBridge.Host.*" minlevel="Info" writeTo="hostFile,console" final="true" />
		<logger name="ZakYip.PlcBridge.Host.*" minlevel="Error" writeTo="errorFile,hostFile,console" final="true" />

		<!-- 项目其余日志统一进 Host -->
		<logger name="ZakYip.PlcBridge.*" minlevel="Info" writeTo="hostFile,console" final="true" />
		<logger name="ZakYip.PlcBridge.*" minlevel="Error" writeTo="errorFile,hostFile,console" final="true" />

		<!-- 控制 Hosting 生命周期日志 -->
		<logger name="Microsoft.Hosting.Lifetime" minlevel="Info" writeTo="hostFile,console" final="true" />

		<!-- 其他全部丢弃，避免噪音 -->
		<logger name="*" minlevel="Trace" writeTo="blackhole" final="true" />
	</rules>
</nlog>
