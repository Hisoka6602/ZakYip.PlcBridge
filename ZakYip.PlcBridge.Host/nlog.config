<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="logs/internal-nlog.txt">

	<!-- 日志输出目标 -->
	<targets>

		<!-- 通用文件日志目标 -->
		<target xsi:type="File" name="allfile"
				fileName="logs/system-provisioner-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/system-provisioner-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- （保留）站点 + 包裹专用日志 -->
		<target xsi:type="File" name="stationParcelFile"
				fileName="logs/station-parcel-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/station-parcel-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- 异常日志 -->
		<target xsi:type="File" name="errorfile"
				fileName="logs/errors-${shortdate}.log"
				layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
				archiveFileName="logs/archives/errors-{#}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="7" />

		<!-- 控制台日志目标 -->
		<target xsi:type="Console" name="lifetimeConsole"
				layout="${level:truncate=4:lowercase=true}\: ${logger}[0]${newline}      ${message}${exception:format=tostring}" />

		<!-- 丢弃用黑洞目标 -->
		<target xsi:type="Null" name="blackhole" />
	</targets>

	<!-- 日志路由规则 -->
	<rules>

		<!-- ========== 1) ElevatorBridgeHostedService ========== -->
		<logger name="ZakYip.PlcBridge.Host.Servers.ElevatorBridgeHostedService*" minlevel="Error" writeTo="errorfile" final="true" />
		<logger name="ZakYip.PlcBridge.Host.Servers.ElevatorBridgeHostedService*" minlevel="Trace" writeTo="allfile" final="true" />
		<logger name="ZakYip.PlcBridge.Host.Servers.ElevatorBridgeHostedService*" minlevel="Information" writeTo="lifetimeConsole" final="true" />

		<!-- ========== 2) S7PlcManager ========== -->
		<logger name="ZakYip.PlcBridge.Drivers.S7PlcManager*" minlevel="Error" writeTo="errorfile" final="true" />
		<logger name="ZakYip.PlcBridge.Drivers.S7PlcManager*" minlevel="Trace" writeTo="allfile" final="true" />
		<logger name="ZakYip.PlcBridge.Drivers.S7PlcManager*" minlevel="Information" writeTo="lifetimeConsole" final="true" />

		<!-- ========== 3) 通用日志（建议仅保留 Program 与 Host Lifetime） ========== -->
		<!-- Host 生命周期 -->
		<logger name="Microsoft.Hosting.Lifetime*" minlevel="Information" writeTo="allfile,lifetimeConsole" final="true" />

		<!-- 顶层 Program（NLog GetCurrentClassLogger 通常是 Program / *.Program） -->
		<logger name="Program" minlevel="Error" writeTo="errorfile" final="true" />
		<logger name="Program" minlevel="Trace" writeTo="allfile" final="true" />
		<logger name="Program" minlevel="Information" writeTo="lifetimeConsole" final="true" />

		<logger name="*.Program" minlevel="Error" writeTo="errorfile" final="true" />
		<logger name="*.Program" minlevel="Trace" writeTo="allfile" final="true" />
		<logger name="*.Program" minlevel="Information" writeTo="lifetimeConsole" final="true" />

		<!-- ========== 4) 其它全部丢弃 ========== -->
		<logger name="*" minlevel="Trace" writeTo="blackhole" final="true" />
	</rules>
</nlog>
