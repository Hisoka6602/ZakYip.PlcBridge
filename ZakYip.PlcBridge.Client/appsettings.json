{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.SignalR.Client": "Debug",
      "Microsoft.AspNetCore.Http.Connections.Client": "Debug",
      "ZakYip.PlcBridge.Client.Services.SignalRMessageClient": "Trace"
    }
  },
  "LogCleanup": {
    "Enabled": true,
    "RetentionDays": 2,
    "CheckIntervalHours": 1,
    "LogDirectory": "logs"
  },
  "SignalRConnectionOptions": {
    "HubUrl": "http://127.0.0.1:8050/hub/plcbridge",
    "IsAutoReconnectEnabled": true,
    "AccessToken": "",
    "Headers": {
      "X-Client": "ZakYip.PlcBridge.Client"
    }
  }
}
